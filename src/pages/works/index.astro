---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/url';

const works = (await getCollection('works')).sort((a, b) => {
  const orderA = a.data.order ?? Number.MAX_SAFE_INTEGER;
  const orderB = b.data.order ?? Number.MAX_SAFE_INTEGER;
  if (orderA !== orderB) return orderA - orderB;
  return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
});
---

<BaseLayout title="Services" description="Contract engagements in cloud architecture, Infrastructure as Code, FinOps, and DevSecOps by Miguel Ramirez Exojo.">
  <section class="page-head section">
    <p class="eyebrow">Services</p>
    <h1>Engagements I take on.</h1>
    <p class="lead">
      Four kinds of contract work, each scoped to a clear outcome: architecture and migration,
      Infrastructure as Code, cloud cost optimization, and DevSecOps delivery pipelines.
    </p>
  </section>

  <section class="section" aria-label="Featured services">
    <div class="work-list">
      {
        works.map((work) => (
          <article class="work-card">
            <p class="entry-meta">{work.data.tech.join(' / ')}</p>
            <h2><a href={withBase(`/works/${work.id}/`)}>{work.data.title}</a></h2>
            <p>{work.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
