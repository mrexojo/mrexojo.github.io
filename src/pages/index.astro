---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';

const works = (await getCollection('works'))
  .sort((a, b) => {
    const byDate = b.data.publishDate.getTime() - a.data.publishDate.getTime();
    return byDate || (a.data.order ?? 999) - (b.data.order ?? 999);
  })
  .slice(0, 3);

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('es', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<BaseLayout
  title="Miguel Ramírez Exojo"
  description="Cloud, DevOps e infraestructura para pymes industriales y empresas IT que necesitan apoyo técnico avanzado."
>
  <section class="hero section">
    <p class="eyebrow">Cloud / DevOps / SRE</p>
    <h1>Infraestructura clara para pymes industriales y partners IT.</h1>
    <p class="lead">
      Diseño y operación de entornos cloud, automatización, continuidad y soporte
      técnico avanzado. Trabajo con equipos que necesitan resolver infraestructura,
      reducir fricción operativa y mantener sistemas fiables sin complicar el día a día.
    </p>
    <div class="action-row" aria-label="Enlaces principales">
      <a class="button" href={withBase('/works/')}>Ver servicios</a>
      <a class="text-link" href={withBase('/blog/')}>Leer artículos</a>
    </div>
  </section>

  <section class="section split-overview" aria-label="Resumen de servicios">
    <div>
      <p class="eyebrow">Qué hago</p>
      <h2>Tecnología útil, estable y entendible.</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Cloud gestionado</h3>
        <p>Migración, operación y optimización de entornos para reducir coste y riesgo.</p>
      </article>
      <article>
        <h3>Automatización</h3>
        <p>Infraestructura como código, flujos repetibles y menos trabajo manual.</p>
      </article>
      <article>
        <h3>Continuidad</h3>
        <p>Backups, replicación, acceso remoto seguro y recuperación pensada para operar.</p>
      </article>
    </div>
  </section>

  <section class="section index-feed" aria-labelledby="latest-works">
    <div class="section-heading">
      <p class="eyebrow">Servicios</p>
      <h2 id="latest-works">Áreas de trabajo.</h2>
      <a class="text-link" href={withBase('/works/')}>Todos los servicios</a>
    </div>

    {
      works.length > 0 ? (
        <div class="highlight-grid">
          {works.map((work) => (
            <article class="highlight-card">
              {work.data.thumbnail && (
                <Image
                  src={work.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(work.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/works/${work.id}/`)}>{work.data.title}</a>
                </h3>
                <p>{work.data.description}</p>
                {work.data.tech.length > 0 && (
                  <ul class="tag-list" aria-label={`Tecnologías de ${work.data.title}`}>
                    {work.data.tech.slice(0, 4).map((tech) => (
                      <li>{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Añade servicios en <code>src/content/works</code> para mostrarlos aquí.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="latest-notes">
    <div class="section-heading">
      <p class="eyebrow">Blog</p>
      <h2 id="latest-notes">Notas técnicas.</h2>
      <a class="text-link" href={withBase('/blog/')}>Todos los posts</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="note-list">
          {posts.map((post) => (
            <article class="note-row">
              {post.data.heroImage && (
                <Image
                  src={post.data.heroImage}
                  alt=""
                  width={320}
                  height={220}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Añade entradas en <code>src/content/blog</code> para mostrarlas aquí.</p>
        </div>
      )
    }
  </section>
</BaseLayout>
