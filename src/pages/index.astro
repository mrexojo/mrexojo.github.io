---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';
import { CONTACT, SOCIAL_LINKS, EXPERIENCE, CERTIFICATIONS, VIDEO_SECTIONS } from '../consts';
import heroImage from '../content/img/mrexojo-cloud.webp';

const works = (await getCollection('works'))
  .sort((a, b) => {
    const byDate = b.data.publishDate.getTime() - a.data.publishDate.getTime();
    return byDate || (a.data.order ?? 999) - (b.data.order ?? 999);
  })
  .slice(0, 3);

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<BaseLayout
  title="Miguel Ramírez Exojo"
  description="Senior cloud infrastructure contractor. Remote B2B engagements across Europe in AWS, GCP, Azure, Terraform, FinOps, and DevSecOps."
>
  <section class="hero section hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Cloud / DevOps / SRE</p>
      <h1>Senior cloud infrastructure contractor.</h1>
      <p class="lead">
        19 years in IT. I design, automate, and operate cloud platforms — architecture and migration,
        Infrastructure as Code, cost optimization, and delivery pipelines — as bounded, remote B2B engagements
        for European engineering teams, delivered from Spain (CET) and handed over when done.
      </p>
      <div class="action-row" aria-label="Main links">
        <a class="button" href={withBase('/works/')}>View services</a>
        <a class="text-link" href={withBase('/blog/')}>Read articles</a>
      </div>
    </div>
    <figure class="hero-media">
      <Image src={heroImage} alt="Cloud infrastructure" width={960} height={1200} sizes="(min-width: 900px) 40vw, 100vw" />
      <figcaption>19 years operating cloud infrastructure — automated, documented, handed over.</figcaption>
    </figure>
  </section>

  <section class="section split-overview" aria-label="Summary of services">
    <div>
      <p class="eyebrow">What I do</p>
      <h2>Infrastructure that works, plainly.</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Architecture & migration</h3>
        <p>Independent senior review and hands-on delivery across AWS, GCP, and Azure.</p>
      </article>
      <article>
        <h3>Automation & IaC</h3>
        <p>Terraform-based infrastructure and pipelines that remove manual steps and stay maintainable.</p>
      </article>
      <article>
        <h3>Cost & delivery security</h3>
        <p>FinOps cost reviews and DevSecOps pipelines with controls auditors accept and engineers keep.</p>
      </article>
    </div>
  </section>

  <section class="section index-feed" id="experience" aria-label="Experience">
    <div class="section-heading">
      <p class="eyebrow">Experience</p>
      <h2>Where I've worked.</h2>
    </div>

    <div class="timeline">
      {EXPERIENCE.map((job) => (
        <article class="timeline-row">
          <div>
            <p class="meta">{job.period}</p>
            <p class="timeline-company">{job.company}</p>
          </div>
          <div>
            <h3>{job.role}</h3>
            <p>{job.description}</p>
            <ul class="tag-list" aria-label={`Stack at ${job.company}`}>
              {job.stack.map((tech) => (
                <li>{tech}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section index-feed" aria-label="Certifications">
    <div class="section-heading">
      <p class="eyebrow">Certifications</p>
      <h2>Always learning.</h2>
    </div>
    <ul class="cert-list" aria-label="Certifications">
      {CERTIFICATIONS.map((cert) => (
        <li>
          <span>{cert.name}</span>
          <span class="meta">{cert.year}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section index-feed" aria-labelledby="latest-works">
    <div class="section-heading">
      <p class="eyebrow">Services</p>
      <h2 id="latest-works">Areas of work.</h2>
      <a class="text-link" href={withBase('/works/')}>All services</a>
    </div>

    {
      works.length > 0 ? (
        <div class="highlight-grid">
          {works.map((work) => (
            <article class="highlight-card">
              {work.data.thumbnail && (
                <Image
                  src={work.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(work.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/works/${work.id}/`)}>{work.data.title}</a>
                </h3>
                <p>{work.data.description}</p>
                {work.data.tech.length > 0 && (
                  <ul class="tag-list" aria-label={`Technologies for ${work.data.title}`}>
                    {work.data.tech.slice(0, 4).map((tech) => (
                      <li>{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
        <p>Add services in <code>src/content/works</code> to show them here.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="latest-notes">
    <div class="section-heading">
      <p class="eyebrow">Blog</p>
      <h2 id="latest-notes">Technical Vision.</h2>
      <a class="text-link" href={withBase('/blog/')}>All posts</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="note-list">
          {posts.map((post) => (
            <article class="note-row">
              {post.data.heroImage && (
                <Image
                  src={post.data.heroImage}
                  alt=""
                  width={320}
                  height={220}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Add posts in <code>src/content/blog</code> to show them here.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="channel">
    <div class="section-heading">
      <p class="eyebrow">Channel</p>
      <h2 id="channel">On @mrexojo.</h2>
      <a class="text-link" href="https://youtube.com/@mrexojo" target="_blank" rel="noopener noreferrer">
        Visit channel
      </a>
    </div>
    <p class="lead channel-intro">
      Organized by the decision it helps you make, not by upload date — pick the topic that matches
      what you're deciding, not the week I recorded it.
    </p>

    <div class="video-sections">
      {VIDEO_SECTIONS.map((section) => (
        <article class="video-section">
          <h3>{section.title}</h3>
          <p>{section.description}</p>
          {section.videos.length > 0 ? (
            <ul class="video-list">
              {section.videos.map((video) => (
                <li>
                  <a href={`https://youtube.com/watch?v=${video.youtubeId}`} target="_blank" rel="noopener noreferrer">
                    <img
                      src={`https://i.ytimg.com/vi/${video.youtubeId}/hqdefault.jpg`}
                      alt=""
                      width={320}
                      height={180}
                      loading="lazy"
                    />
                    <span>{video.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="video-empty">Videos coming soon.</p>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="section contact-section" id="contact" aria-labelledby="contact-heading">
    <div class="split-overview">
      <div>
        <p class="eyebrow">Contact</p>
        <h2 id="contact-heading">Get in touch.</h2>
        <p class="lead">
          For scoping a cloud architecture review, a Terraform build, a cost audit, or a DevSecOps
          pipeline — book a call or write directly.
        </p>
      </div>
      <div class="contact-channels">
        <a class="channel-row" href={`mailto:${CONTACT.email}`}>
          <span class="meta">Email</span>
          <span>{CONTACT.email}</span>
        </a>
        <button class="channel-row" type="button" data-book-call aria-label="Book a call"></button>
        {SOCIAL_LINKS.map((social) => (
          <a class="channel-row" href={social.href} target="_blank" rel="noopener noreferrer">
            <span class="meta">{social.label}</span>
            <span>@mrexojo</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
