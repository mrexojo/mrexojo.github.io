---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';

const works = (await getCollection('works'))
  .sort((a, b) => {
    const byDate = b.data.publishDate.getTime() - a.data.publishDate.getTime();
    return byDate || (a.data.order ?? 999) - (b.data.order ?? 999);
  })
  .slice(0, 3);

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<BaseLayout
  title="Miguel Ramírez Exojo"
  description="Cloud, DevOps and infrastructure for industrial SMEs and IT companies needing advanced technical support."
>
  <section class="hero section">
    <p class="eyebrow">Cloud / DevOps / SRE</p>
    <h1>Clear infrastructure for industrial SMEs and IT partners.</h1>
    <p class="lead">
      Design and operation of cloud platforms, automation, continuity, and advanced technical support. I work with teams solving infrastructure,
      reducing operational friction, and keeping systems reliable without adding unnecessary complexity.
    </p>
    <div class="action-row" aria-label="Main links">
      <a class="button" href={withBase('/works/')}>View services</a>
      <a class="text-link" href={withBase('/blog/')}>Read articles</a>
    </div>
  </section>

  <section class="section split-overview" aria-label="Summary of services">
    <div>
      <p class="eyebrow">What I do</p>
      <h2>Useful, stable, understandable technology.</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Managed cloud</h3>
        <p>Migration, operation and optimization to reduce cost and risk.</p>
      </article>
      <article>
        <h3>Automation</h3>
        <p>Infrastructure as Code, repeatable flows and less manual work.</p>
      </article>
      <article>
        <h3>Continuity</h3>
        <p>Backups, replication, secure remote access and recovery designed for operations.</p>
      </article>
    </div>
  </section>

  <section class="section index-feed" aria-labelledby="latest-works">
    <div class="section-heading">
      <p class="eyebrow">Services</p>
      <h2 id="latest-works">Areas of work.</h2>
      <a class="text-link" href={withBase('/works/')}>All services</a>
    </div>

    {
      works.length > 0 ? (
        <div class="highlight-grid">
          {works.map((work) => (
            <article class="highlight-card">
              {work.data.thumbnail && (
                <Image
                  src={work.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(work.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/works/${work.id}/`)}>{work.data.title}</a>
                </h3>
                <p>{work.data.description}</p>
                {work.data.tech.length > 0 && (
                  <ul class="tag-list" aria-label={`Technologies for ${work.data.title}`}>
                    {work.data.tech.slice(0, 4).map((tech) => (
                      <li>{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
        <p>Add services in <code>src/content/works</code> to show them here.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="latest-notes">
    <div class="section-heading">
      <p class="eyebrow">Blog</p>
      <h2 id="latest-notes">Technical notes.</h2>
      <a class="text-link" href={withBase('/blog/')}>All posts</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="note-list">
          {posts.map((post) => (
            <article class="note-row">
              {post.data.heroImage && (
                <Image
                  src={post.data.heroImage}
                  alt=""
                  width={320}
                  height={220}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Add posts in <code>src/content/blog</code> to show them here.</p>
        </div>
      )
    }
  </section>
</BaseLayout>
