---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/url';

const bundlePath = withBase('/pagefind/');
---

<BaseLayout title="Search" description="Search site articles and services.">
  <section class="page-head section">
    <p class="eyebrow">Search</p>
    <h1>Find articles and services.</h1>
    <p class="lead">
      Static search with Pagefind. Index generated at build time, no extra backend required.
    </p>
  </section>

  <section class="section search-section" aria-label="Site search">
    <link rel="stylesheet" href={`${bundlePath}pagefind-ui.css`} />
    <div id="search">
      <p class="search-fallback">
        Index generated at build. Run <code>npm run build</code> and open compiled
        version to test; not available on dev server.
      </p>
    </div>
    <script is:inline define:vars={{ bundlePath }}>
      const script = document.createElement('script');
      script.src = `${bundlePath}pagefind-ui.js`;
      script.onload = () => {
        document.querySelector('#search .search-fallback')?.remove();
        new PagefindUI({
          element: '#search',
          bundlePath,
          showImages: false,
          showSubResults: true,
          autofocus: true,
        });
      };
      document.head.append(script);
    </script>
  </section>
</BaseLayout>
