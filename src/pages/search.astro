---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/url';

const bundlePath = withBase('/pagefind/');
---

<BaseLayout title="Buscar" description="Busca artículos y servicios del sitio.">
  <section class="page-head section">
    <p class="eyebrow">Buscar</p>
    <h1>Encuentra artículos y servicios.</h1>
    <p class="lead">
      Búsqueda estática con Pagefind. El índice se genera al construir el sitio, sin
      backend adicional.
    </p>
  </section>

  <section class="section search-section" aria-label="Buscador del sitio">
    <link rel="stylesheet" href={`${bundlePath}pagefind-ui.css`} />
    <div id="search">
      <p class="search-fallback">
        El índice se genera en build. Ejecuta <code>npm run build</code> y abre la
        versión compilada para probarlo; no está disponible en el servidor de desarrollo.
      </p>
    </div>
    <script is:inline define:vars={{ bundlePath }}>
      const script = document.createElement('script');
      script.src = `${bundlePath}pagefind-ui.js`;
      script.onload = () => {
        document.querySelector('#search .search-fallback')?.remove();
        new PagefindUI({
          element: '#search',
          bundlePath,
          showImages: false,
          showSubResults: true,
          autofocus: true,
        });
      };
      document.head.append(script);
    </script>
  </section>
</BaseLayout>
