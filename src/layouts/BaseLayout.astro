---
import '@fontsource-variable/fraunces/opsz.css';
import '@fontsource/public-sans/400.css';
import '@fontsource/public-sans/500.css';
import '@fontsource/public-sans/600.css';
import '@fontsource/public-sans/700.css';
import '@fontsource-variable/jetbrains-mono/wght.css';
import '../styles/global.css';
import { withBase } from '../lib/url';
import { SITE, NAV_ITEMS, CONTACT, SOCIAL_LINKS } from '../consts';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  image?: string;
}

const siteName = SITE.title;

const {
  title = siteName,
  description = SITE.description,
  ogType = 'website',
  image,
} = Astro.props;

// `Astro.site` comes from `site` in astro.config.mjs; fall back to the
// request URL during dev so canonical/OG links still resolve.
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const imageURL = image ? new URL(image, siteBase) : new URL(withBase(SITE.ogImage), siteBase);
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  const full = withBase(href);
  return href === '/' ? currentPath === full : currentPath.startsWith(full);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href={withBase('/rss.xml')} />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {imageURL && <meta property="og:image" content={imageURL} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={imageURL ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}

    <!-- Google Calendar scheduling button (loaded site-wide for header/contact) -->
    <link rel="stylesheet" href="https://calendar.google.com/calendar/scheduling-button-script.css">
    <script async src="https://calendar.google.com/calendar/scheduling-button-script.js"></script>

    <script is:inline>
      const storedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.dataset.theme = storedTheme || (prefersDark ? 'dark' : 'light');
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase('/')} aria-label={`Home of ${siteName}`}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-name" aria-hidden="true">
          <span class="brand-name-track" data-brand-track>
            <span class="brand-name-text">{siteName}</span>
            <span class="brand-name-text">Mr.Exojo</span>
          </span>
        </span>
      </a>
      <nav class="site-nav" aria-label="Main navigation">
        {
          NAV_ITEMS.map((item) => (
            <a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="header-actions">
        <button class="button" type="button" aria-label="Book a call" data-book-call></button>
        <button class="theme-toggle" type="button" aria-label="Toggle color theme" data-theme-toggle>
          <span aria-hidden="true"></span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>{SITE.footerText}</p>
      <nav class="footer-links" aria-label="Social and contact">
        <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
        {SOCIAL_LINKS.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer">
            {social.label}
          </a>
        ))}
      </nav>
    </footer>

    <script>
      const toggle = document.querySelector('[data-theme-toggle]');
      toggle?.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme;
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>

    <script>
      const brandTrack = document.querySelector('[data-brand-track]');
      if (brandTrack instanceof HTMLElement) {
        let showShort = false;
        setInterval(() => {
          showShort = !showShort;
          brandTrack.style.transform = showShort ? 'translateY(-1.2em)' : 'translateY(0)';
        }, 6000);
      }
    </script>

    <script define:vars={{ calendarUrl: CONTACT.calendarUrl }}>
      // Mounts the Google Calendar scheduling widget into every [data-book-call]
      // element on the page (header button, contact section, etc).
      window.addEventListener('load', () => {
        const targets = document.querySelectorAll('[data-book-call]');
        // @ts-expect-error - injected by the Google Calendar script
        if (!targets.length || !window.calendar?.schedulingButton?.load) return;
        targets.forEach((target) => {
          // @ts-expect-error - injected by the Google Calendar script
          calendar.schedulingButton.load({
            url: calendarUrl,
            color: '#B14A31', // matches --color-accent (light theme)
            label: 'Book a call',
            target,
          });
        });
      });
    </script>
  </body>
</html>
